# Local dev secrets — never commit
dev.sh
build.sh
android/key.properties
android/pigio-release.jks
# Google OAuth client secret files — CRITICAL: never commit
**/client_secret_*.json
# Firebase — CRITICAL: private key must never be committed
android/app/*firebase-adminsdk*.json
android/app/google-services.json
ios/Runner/GoogleService-Info.plist

# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/build/**
/build/app/outputs/
/build/app/intermediates/
/build/app/tmp/
/build/macos/
/build/ios/
/build/native_assets/
/build/reports/
/build/last_build_run.json
/docs/*.apk
/docs/*.aab
/docs/**/*.apk
/docs/**/*.aab
# Billing / financial exports
/docs/*.csv
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Firebase config — contains API keys, never commit these
android/app/google-services.json
ios/Runner/GoogleService-Info.plist

# Supabase temp files (pooler URL, project ref) — never commit
supabase/.temp/

# Dart-define env files — contain secrets, inject via CI
*.env
.env.*

# Binary archives and installers — too large for git
*.tar.gz
*.zip
*.dmg
*.pkg
