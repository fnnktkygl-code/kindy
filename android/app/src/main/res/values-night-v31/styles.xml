<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Android 12+ splash screen: dark mode — no icon background circle -->
    <style name="LaunchTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
        <item name="android:windowSplashScreenBackground">@color/splash_bg_dark</item>
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/app_icon</item>
        <item name="android:windowSplashScreenIconBackgroundColor">@color/splash_bg_dark</item>
    </style>
    <color name="splash_bg_dark">#12131F</color>
</resources>
