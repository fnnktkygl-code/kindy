<?xml version="1.0" encoding="utf-8"?>
<!--
  Network Security Config — Pigio
  • Forbids cleartext (HTTP) traffic on ALL API levels (including 24-27).
  • Uses system CA store only.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
